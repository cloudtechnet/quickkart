        <mxCell id="de1CSgN9PqiGxVbJEV4K-8" value="&lt;div&gt;const assert = require(&#39;assert&#39;);&lt;/div&gt;&lt;div&gt;const add = require(&#39;./add&#39;);&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;describe(&#39;Addition Function Test&#39;, function () {&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; it(&#39;should return 5 when adding 2 and 3&#39;, function () {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; assert.equal(add(2, 3), 5);&lt;/div&gt;&lt;div&gt;&amp;nbsp; });&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; it(&#39;should return 0 when adding -1 and 1&#39;, function () {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; assert.equal(add(-1, 1), 0);&lt;/div&gt;&lt;div&gt;&amp;nbsp; });&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;});&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="de1CSgN9PqiGxVbJEV4K-7">
